# Generated by Ansible for {{ inventory_hostname }}
auto lo
iface lo inet loopback

allow-hotplug {{ mgmt_interface }}
iface {{ mgmt_interface }} inet static
    address {{ mgmt_ip_cidr }}
    gateway {{ mgmt_gateway }}

{% for bridge in leaf_bridges %}
auto {{ bridge.name }}
iface {{ bridge.name }} inet manual
    bridge_ports {{ bridge.ports | join(' ') }}
    bridge_stp off
    bridge_fd 0
    bridge_vlan_aware {{ 'yes' if leaf_bridge_vlan_aware else 'no' }}

{% endfor %}
{% for svi in leaf_svis %}
auto {{ svi.name }}
iface {{ svi.name }} inet static
    address {{ svi.address }}
    vlan-raw-device {{ svi.raw_device }}

{% endfor %}
