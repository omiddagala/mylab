#!/usr/sbin/nft -f
flush ruleset

table inet filter {
  chain input {
    type filter hook input priority 0; policy accept;
  }

  chain forward {
    type filter hook forward priority 0; policy drop;
    ct state established,related accept
    iifname { "br-mgmt", "br-wan", "br-dc1", "br-dc2" } oifname "{{ mylab_uplink_interface }}" accept
    iifname "{{ mylab_uplink_interface }}" oifname { "br-mgmt", "br-wan", "br-dc1", "br-dc2" } ct state established,related accept
    iifname "br-wan" oifname { "br-dc1", "br-dc2" } accept
    iifname { "br-dc1", "br-dc2" } oifname "br-wan" accept
  }
}

table ip nat {
  chain postrouting {
    type nat hook postrouting priority 100; policy accept;
    oifname "{{ mylab_uplink_interface }}" ip saddr { {{ mylab_mgmt_bridge_cidr }}, {{ mylab_wan_bridge_cidr }}, {{ mylab_dc1_bridge_cidr }}, {{ mylab_dc2_bridge_cidr }} } masquerade
  }
}
