#cloud-config
hostname: {{ item.name }}
manage_etc_hosts: true
users:
  - name: {{ mylab_default_username }}
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    ssh_authorized_keys:
      - {{ mylab_ssh_public_key }}
package_update: true
packages:
  - qemu-guest-agent
  - curl
  - python3
runcmd:
  - [ systemctl, enable, --now, qemu-guest-agent ]
